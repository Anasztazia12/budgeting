# Email API server
EMAIL_API_PORT=3001

# Optional comma-separated CORS allowlist (leave empty to allow all)
EMAIL_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# SMTP config
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password-or-app-password

# Sender address shown in outgoing emails
EMAIL_FROM=Budgeting App <your-smtp-user@example.com>
